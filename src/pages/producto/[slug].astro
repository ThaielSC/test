---
export const prerender = true;

import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import ProductCard from '../../components/ProductCard.astro';

export async function getStaticPaths() {
  const products = await getCollection('products');
  return products.map(product => ({
    params: { slug: product.data.slug },
    props: { product: product.data },
  }));
}

const { product } = Astro.props;

// Get related products (same category, excluding current)
const allProducts = await getCollection('products');
const relatedProducts = allProducts
  .filter(p => p.data.category === product.category && p.data.slug !== product.slug)
  .slice(0, 3);
---

<BaseLayout title={product.name} description={product.description}>
  <Header slot="header" />

  <section class="product-detail" id="product-detail">
    <div class="container">
      <nav class="breadcrumb" id="breadcrumb">
        <a href="/">Inicio</a>
        <span class="breadcrumb-sep">›</span>
        <a href="/menu">Menú</a>
        <span class="breadcrumb-sep">›</span>
        <span>{product.name}</span>
      </nav>

      <div class="product-grid">
        <div class="product-image-section animate-fade-in">
          <div class="product-image-large">
            <img src={product.image} alt={product.name} />
          </div>
          {product.featured && (
            <div class="featured-badge">
              <span class="badge badge-featured">⭐ Favorito de la casa</span>
            </div>
          )}
        </div>

        <div class="product-info-section animate-fade-in-up">
          <span class="badge badge-category">{product.category}</span>
          <h1 class="product-title">{product.name}</h1>
          <div class="doodle-line"></div>
          <p class="product-description">{product.description}</p>

          {product.tags && product.tags.length > 0 && (
            <div class="product-tags">
              {product.tags.map((tag: string) => (
                <span class="tag">#{tag}</span>
              ))}
            </div>
          )}

          <div class="product-purchase">
            <div class="product-price">
              <span class="price-label">Precio</span>
              <span class="price" style="font-size: 2rem;">
                <span class="price-currency">$</span>{product.price.toFixed(2)}
              </span>
            </div>

            <div class="product-quantity">
              <button class="qty-btn" id="qty-decrease" aria-label="Disminuir cantidad">−</button>
              <span class="qty-value" id="qty-value">1</span>
              <button class="qty-btn" id="qty-increase" aria-label="Aumentar cantidad">+</button>
            </div>
          </div>

          <button class="btn btn-primary btn-add-cart" id="add-to-cart-detail" data-product={product.slug}>
            Agregar al Carrito
            <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
              <circle cx="9" cy="21" r="1"/><circle cx="20" cy="21" r="1"/>
              <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
            </svg>
          </button>
        </div>
      </div>
    </div>
  </section>

  <!-- Related Products -->
  {relatedProducts.length > 0 && (
    <section class="section related-section" id="related-products">
      <div class="container">
        <div class="section-header">
          <span class="section-label star-deco">También te puede gustar</span>
          <h2>Más de {product.category}</h2>
        </div>
        <div class="grid grid-3 stagger">
          {relatedProducts.map(p => (
            <ProductCard {...p.data} />
          ))}
        </div>
      </div>
    </section>
  )}

  <Footer slot="footer" />
</BaseLayout>

<style>
  .product-detail {
    padding-top: calc(var(--header-height) + var(--space-2xl));
  }

  .breadcrumb {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.85rem;
    color: var(--text-muted);
    margin-bottom: var(--space-2xl);
  }

  .breadcrumb a {
    color: var(--text-muted);
    transition: color var(--duration-fast);
  }

  .breadcrumb a:hover {
    color: var(--color-caramel);
  }

  .breadcrumb-sep {
    opacity: 0.4;
  }

  .product-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: start;
  }

  .product-image-section {
    position: relative;
  }

  .product-image-large {
    background: linear-gradient(145deg, var(--color-parchment), var(--color-cream-dark));
    border-radius: var(--radius-xl);
    border: 2px solid var(--border-color);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-4xl);
    aspect-ratio: 1;
  }

  .product-image-large img {
    max-width: 280px;
    max-height: 280px;
    object-fit: contain;
    filter: drop-shadow(0 12px 24px rgba(42, 24, 16, 0.15));
    animation: float 5s var(--ease-out) infinite;
  }

  .featured-badge {
    position: absolute;
    top: var(--space-lg);
    left: var(--space-lg);
  }

  .product-info-section {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .product-info-section .badge-category {
    align-self: flex-start;
  }

  .product-title {
    font-size: clamp(2rem, 4vw, 2.8rem);
    line-height: 1.1;
  }

  .product-description {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .product-tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-sm);
  }

  .tag {
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--color-caramel);
    background: rgba(212, 146, 42, 0.08);
    padding: 4px 12px;
    border-radius: var(--radius-full);
  }

  .product-purchase {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-lg) 0;
    border-top: 1px dashed var(--border-color);
    border-bottom: 1px dashed var(--border-color);
  }

  .price-label {
    display: block;
    font-size: 0.8rem;
    font-weight: 500;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    margin-bottom: var(--space-xs);
  }

  .product-quantity {
    display: flex;
    align-items: center;
    gap: var(--space-md);
    background: var(--bg-secondary);
    border-radius: var(--radius-full);
    padding: var(--space-xs);
  }

  .qty-btn {
    width: 36px;
    height: 36px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    font-size: 1.2rem;
    font-weight: 600;
    color: var(--text-primary);
    background: white;
    border: 1px solid var(--border-color);
    transition: all var(--duration-fast);
  }

  .qty-btn:hover {
    background: var(--color-caramel);
    color: white;
    border-color: var(--color-caramel);
  }

  .qty-value {
    font-size: 1.1rem;
    font-weight: 600;
    min-width: 28px;
    text-align: center;
  }

  .btn-add-cart {
    width: 100%;
    padding: var(--space-lg);
    font-size: 1.05rem;
  }

  .related-section {
    background: var(--bg-secondary);
    border-radius: var(--radius-xl) var(--radius-xl) 0 0;
    margin-top: var(--space-4xl);
  }

  @media (max-width: 768px) {
    .product-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .product-image-large {
      aspect-ratio: auto;
      padding: var(--space-3xl);
    }

    .product-image-large img {
      max-width: 200px;
      max-height: 200px;
    }
  }
</style>

<script>
  const decreaseBtn = document.getElementById('qty-decrease');
  const increaseBtn = document.getElementById('qty-increase');
  const qtyValue = document.getElementById('qty-value');
  let quantity = 1;

  decreaseBtn?.addEventListener('click', () => {
    if (quantity > 1) {
      quantity--;
      if (qtyValue) qtyValue.textContent = String(quantity);
    }
  });

  increaseBtn?.addEventListener('click', () => {
    if (quantity < 10) {
      quantity++;
      if (qtyValue) qtyValue.textContent = String(quantity);
    }
  });
</script>
