---
import { getCollection, getEntry } from 'astro:content';
import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import Hero from '../components/Hero.astro';
import ProductCard from '../components/ProductCard.astro';

const homePageEntry = await getEntry('pages', 'home');
const homePage = homePageEntry?.data;

const allProducts = await getCollection('products');
const featuredProducts = allProducts.filter(p => p.data.featured);

const heroSection = homePage?.sections.find(s => s.type === 'hero');
const featuredSection = homePage?.sections.find(s => s.type === 'featured');
const ctaSection = homePage?.sections.find(s => s.type === 'cta');
---

<BaseLayout title="Inicio" description={homePage?.description}>
  <Header slot="header" />

  {heroSection && (
    <Hero
      heading={heroSection.content.heading}
      subheading={heroSection.content.subheading}
      ctaText={heroSection.content.ctaText}
      ctaLink={heroSection.content.ctaLink}
    />
  )}

  <!-- Featured Products -->
  <section class="section" id="featured-section">
    <div class="container">
      <div class="section-header">
        <span class="section-label star-deco">{featuredSection?.content?.subheading || 'Los más pedidos'}</span>
        <h2>{featuredSection?.content?.heading || 'Nuestros Favoritos'}</h2>
        <div class="doodle-line" style="margin: var(--space-lg) auto 0"></div>
      </div>

      <div class="grid grid-3 stagger">
        {featuredProducts.map(product => (
          <ProductCard {...product.data} />
        ))}
      </div>

      <div class="section-cta">
        <a href="/menu" class="btn btn-secondary">
          Ver Todo el Menú
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
            <path d="M5 12h14M12 5l7 7-7 7"/>
          </svg>
        </a>
      </div>
    </div>
  </section>

  <!-- CTA Section -->
  {ctaSection && (
    <section class="cta-section section" id="cta-section">
      <div class="container">
        <div class="cta-card">
          <div class="cta-content">
            <h2>{ctaSection.content.heading}</h2>
            <p>{ctaSection.content.subheading}</p>
            <a href={ctaSection.content.ctaLink} class="btn btn-primary">
              {ctaSection.content.ctaText}
            </a>
          </div>
          <div class="cta-deco">
            <svg viewBox="0 0 200 200" fill="none" xmlns="http://www.w3.org/2000/svg" class="cta-illustration">
              <!-- Simplified coffee beans -->
              <ellipse cx="60" cy="80" rx="30" ry="45" transform="rotate(-20 60 80)" fill="#2A1810" opacity="0.1"/>
              <path d="M45 65 Q60 80 45 95" stroke="#2A1810" stroke-width="2" opacity="0.15"/>
              <ellipse cx="140" cy="120" rx="25" ry="38" transform="rotate(15 140 120)" fill="#2A1810" opacity="0.08"/>
              <path d="M128 105 Q140 120 128 135" stroke="#2A1810" stroke-width="2" opacity="0.12"/>
              <!-- Decorative stars -->
              <text x="100" y="50" font-size="24" opacity="0.15">✦</text>
              <text x="30" y="150" font-size="18" opacity="0.1">✦</text>
              <text x="160" y="60" font-size="16" opacity="0.12">✦</text>
            </svg>
          </div>
        </div>
      </div>
    </section>
  )}

  <Footer slot="footer" />
</BaseLayout>

<style>
  .section-cta {
    text-align: center;
    margin-top: var(--space-3xl);
  }

  /* CTA Section */
  .cta-section {
    padding-bottom: 0;
  }

  .cta-card {
    position: relative;
    background: linear-gradient(135deg, var(--color-ink) 0%, var(--color-coffee) 100%);
    border-radius: var(--radius-xl);
    padding: var(--space-4xl);
    text-align: center;
    overflow: hidden;
  }

  .cta-content {
    position: relative;
    z-index: 1;
  }

  .cta-card h2 {
    color: var(--color-cream);
    margin-bottom: var(--space-md);
  }

  .cta-card p {
    color: rgba(253, 246, 236, 0.7);
    margin: 0 auto var(--space-2xl);
    font-size: 1.1rem;
  }

  .cta-card .btn-primary {
    background: var(--color-caramel);
    border-color: var(--color-caramel);
    color: white;
  }

  .cta-card .btn-primary:hover {
    background: var(--color-caramel-light);
    border-color: var(--color-caramel-light);
  }

  .cta-deco {
    position: absolute;
    inset: 0;
    pointer-events: none;
  }

  .cta-illustration {
    width: 100%;
    height: 100%;
  }

  @media (max-width: 768px) {
    .cta-card {
      padding: var(--space-3xl) var(--space-xl);
    }
  }
</style>
