---
export const prerender = true;

import BaseLayout from '../layouts/BaseLayout.astro';
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';
import { getEntry } from 'astro:content';

const aboutPageEntry = await getEntry('pages', 'about');
const aboutPage = aboutPageEntry?.data;

const heroSection = aboutPage?.sections?.find(s => s.type === 'hero')?.content || {
  label: 'Nuestra Historia',
  heading: 'Más que café, es alma',
  subheading: 'Desde 2020, tostando granos seleccionados a mano con la misma pasión del primer día.'
};

const textSection = aboutPage?.sections?.find(s => s.type === 'text')?.content || {
  heading: 'De un sueño a tu taza',
  paragraph1: 'Greda nació de la idea simple de que el café puede ser más que una bebida — puede ser una experiencia. Seleccionamos granos de origen único, los tostamos en pequeños lotes y los preparamos con el cuidado que cada taza merece.',
  paragraph2: 'Nuestro nombre, "Greda", viene de la arcilla con la que se moldean las tazas artesanales. Como la greda, creemos que las mejores cosas se hacen a mano, con paciencia y con amor.'
};
---

<BaseLayout title={aboutPage?.title || "Nosotros"} description={aboutPage?.description || "Conoce la historia detrás de Greda Café — nuestro amor por el café artesanal."}>
  <Header slot="header" />

  <section class="about-hero" id="about-hero">
    <div class="container">
      <span class="section-label star-deco">{heroSection.label}</span>
      <h1>{heroSection.heading}</h1>
      <p class="about-subtitle">{heroSection.subheading}</p>
    </div>
  </section>

  <section class="section about-story" id="about-story">
    <div class="container">
      <div class="story-grid">
        <div class="story-content animate-fade-in-up">
          <h2>{textSection.heading}</h2>
          <div class="doodle-line"></div>
          <p>{textSection.paragraph1}</p>
          <p>{textSection.paragraph2}</p>
        </div>
        <div class="story-visual animate-fade-in" style="animation-delay: 200ms">
          <div class="story-illustration">
            <svg viewBox="0 0 300 300" fill="none" xmlns="http://www.w3.org/2000/svg">
              <!-- Coffee bean characters -->
              <ellipse cx="100" cy="150" rx="40" ry="60" transform="rotate(-15 100 150)" fill="#6B3A2A" stroke="#2A1810" stroke-width="3"/>
              <path d="M80 120 Q100 150 80 180" stroke="#2A1810" stroke-width="2.5" fill="none"/>
              <!-- Bean face -->
              <ellipse cx="90" cy="140" rx="4" ry="5" fill="#2A1810"/>
              <ellipse cx="108" cy="135" rx="4" ry="5" fill="#2A1810"/>
              <path d="M88 155 Q98 162 108 152" stroke="#2A1810" stroke-width="2" fill="none" stroke-linecap="round"/>
              
              <!-- Second bean -->
              <ellipse cx="200" cy="160" rx="35" ry="55" transform="rotate(10 200 160)" fill="#8B5A3A" stroke="#2A1810" stroke-width="3"/>
              <path d="M185 130 Q200 160 185 190" stroke="#2A1810" stroke-width="2.5" fill="none"/>
              <!-- Bean face -->
              <ellipse cx="193" cy="150" rx="4" ry="5" fill="#2A1810"/>
              <ellipse cx="210" cy="148" rx="4" ry="5" fill="#2A1810"/>
              <path d="M195 167 Q205 174 215 165" stroke="#2A1810" stroke-width="2" fill="none" stroke-linecap="round"/>
              
              <!-- Hearts -->
              <path d="M140 110 Q136 104 140 100 Q144 96 148 100 Q152 96 156 100 Q160 104 156 110 L148 120 Z" fill="#C45D3E" opacity="0.5"/>
              <path d="M155 200 Q152 196 155 193 Q158 190 161 193 Q164 190 167 193 Q170 196 167 200 L161 206 Z" fill="#D4922A" opacity="0.4"/>
              
              <!-- Sparkles -->
              <text x="60" y="100" font-size="16" opacity="0.2">✦</text>
              <text x="230" y="110" font-size="12" opacity="0.15">✦</text>
              <text x="150" y="250" font-size="14" opacity="0.18">✦</text>
            </svg>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section class="section about-values" id="about-values">
    <div class="container">
      <div class="section-header">
        <span class="section-label star-deco">Nuestros Valores</span>
        <h2>Lo que nos mueve</h2>
      </div>
      <div class="grid grid-3 stagger">
        <div class="value-card">
          <span class="value-icon">🌱</span>
          <h3>Origen Responsable</h3>
          <p>Trabajamos directamente con productores, asegurando precios justos y prácticas sostenibles.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">🔥</span>
          <h3>Tostado Artesanal</h3>
          <p>Cada lote es tostado en pequeñas cantidades para garantizar frescura y el perfil de sabor perfecto.</p>
        </div>
        <div class="value-card">
          <span class="value-icon">💛</span>
          <h3>Hecho con Amor</h3>
          <p>Desde el grano hasta la taza, cada paso es cuidado con la dedicación que tu café merece.</p>
        </div>
      </div>
    </div>
  </section>

  <Footer slot="footer" />
</BaseLayout>

<style>
  .about-hero {
    padding-top: calc(var(--header-height) + var(--space-4xl));
    padding-bottom: var(--space-3xl);
    text-align: center;
    background: linear-gradient(180deg, var(--color-parchment) 0%, var(--bg-primary) 100%);
  }

  .about-subtitle {
    margin: var(--space-md) auto 0;
    font-size: 1.1rem;
    max-width: 55ch;
  }

  .story-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: var(--space-4xl);
    align-items: center;
  }

  .story-content {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .story-content p {
    font-size: 1.05rem;
    line-height: 1.8;
  }

  .story-illustration {
    background: linear-gradient(145deg, var(--color-parchment), var(--color-cream-dark));
    border-radius: var(--radius-xl);
    border: 2px solid var(--border-color);
    padding: var(--space-3xl);
  }

  .story-illustration svg {
    width: 100%;
    height: auto;
  }

  .value-card {
    text-align: center;
    padding: var(--space-2xl);
    background: var(--bg-card);
    border-radius: var(--radius-lg);
    border: 2px solid var(--border-color);
    transition: all var(--duration-normal) var(--ease-out);
  }

  .value-card:hover {
    transform: translateY(-4px);
    box-shadow: var(--shadow-lg);
    border-color: var(--color-caramel);
  }

  .value-icon {
    font-size: 2.5rem;
    display: block;
    margin-bottom: var(--space-lg);
  }

  .value-card h3 {
    margin-bottom: var(--space-sm);
  }

  .value-card p {
    font-size: 0.9rem;
    margin: 0 auto;
  }

  @media (max-width: 768px) {
    .story-grid {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .story-visual {
      order: -1;
    }
  }
</style>
