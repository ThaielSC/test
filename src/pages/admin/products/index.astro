---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getCollection } from 'astro:content';
import ProductList from '../../../components/admin/ProductList';

const user = Astro.locals.user;

// Obtener los productos publicados actualmente en local/git
const products = await getCollection('products');

// Simplificar los datos para enviarlos al componente Preact
const initialProducts = products.map(p => ({
  id: p.id,
  slug: p.data.slug || p.id,
  body: p.body,
  collection: p.collection,
  data: p.data
}));
---

<AdminLayout title="Productos">
  <!-- El componente ProductList usa Preact. client:load asegura que se vuelva interactivo inmediatamente -->
  <ProductList client:load initialProducts={initialProducts} />
</AdminLayout>
