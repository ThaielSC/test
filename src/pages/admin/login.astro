---
export const prerender = false;

// Si ya está logueado, redirigir al admin
if (Astro.locals.user) {
  return Astro.redirect('/admin');
}
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Login — Greda CMS</title>
    <link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700&family=Playfair+Display:ital,wght@0,700;1,700&display=swap" rel="stylesheet">
    <style>
      :root {
        --color-cream: #FDF6EC;
        --color-cream-dark: #F5E6CC;
        --color-ink: #2A1810;
        --color-caramel: #D4922A;
        --color-rust: #C45D3E;
        --radius-lg: 16px;
      }

      * { box-sizing: border-box; margin: 0; padding: 0; }

      body {
        font-family: 'Outfit', sans-serif;
        background: var(--color-cream);
        color: var(--color-ink);
        display: flex;
        align-items: center;
        justify-content: center;
        min-height: 100vh;
        background-image: radial-gradient(var(--color-cream-dark) 1px, transparent 1px);
        background-size: 20px 20px;
      }

      .login-container {
        width: 100%;
        max-width: 400px;
        padding: 2rem;
      }

      .logo-container {
        text-align: center;
        margin-bottom: 2rem;
      }

      .logo-icon {
        margin: 0 auto 1rem;
        display: block;
      }

      h1 {
        font-family: 'Playfair Display', serif;
        font-size: 2rem;
        color: var(--color-ink);
        margin-bottom: 0.5rem;
      }

      p.subtitle {
        color: rgba(42, 24, 16, 0.6);
        font-size: 0.95rem;
      }

      .login-card {
        background: white;
        padding: 2.5rem 2rem;
        border-radius: var(--radius-lg);
        border: 2px solid var(--color-cream-dark);
        box-shadow: 0 10px 30px rgba(42, 24, 16, 0.05);
      }

      .form-group {
        margin-bottom: 1.5rem;
      }

      label {
        display: block;
        font-size: 0.85rem;
        font-weight: 600;
        margin-bottom: 0.5rem;
        color: var(--color-ink);
      }

      input {
        width: 100%;
        padding: 0.8rem 1rem;
        border: 2px solid var(--color-cream-dark);
        border-radius: 8px;
        font-family: inherit;
        font-size: 1rem;
        transition: all 0.2s;
        background: #fafafa;
      }

      input:focus {
        outline: none;
        border-color: var(--color-caramel);
        background: white;
      }

      .btn {
        width: 100%;
        padding: 1rem;
        background: var(--color-ink);
        color: white;
        border: none;
        border-radius: 8px;
        font-family: inherit;
        font-size: 1rem;
        font-weight: 600;
        cursor: pointer;
        transition: all 0.2s;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 0.5rem;
      }

      .btn:hover {
        background: var(--color-caramel);
        transform: translateY(-2px);
      }

      .btn:disabled {
        opacity: 0.7;
        cursor: not-allowed;
        transform: none;
      }

      .error-msg {
        color: var(--color-rust);
        font-size: 0.85rem;
        text-align: center;
        margin-top: 1rem;
        min-height: 20px;
        font-weight: 500;
      }

      /* Loader */
      .loader {
        width: 18px;
        height: 18px;
        border: 2px solid rgba(255,255,255,0.3);
        border-radius: 50%;
        border-top-color: white;
        animation: spin 1s ease-in-out infinite;
        display: none;
      }

      @keyframes spin {
        to { transform: rotate(360deg); }
      }

      .loading .loader {
        display: block;
      }
      .loading .btn-text {
        display: none;
      }

      .demo-hint {
        margin-top: 2rem;
        text-align: center;
        font-size: 0.8rem;
        color: rgba(42, 24, 16, 0.5);
        background: var(--color-cream-dark);
        padding: 0.75rem;
        border-radius: 8px;
      }
    </style>
  </head>
  <body>
    <div class="login-container">
      <div class="logo-container">
        <svg class="logo-icon" width="48" height="48" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
          <circle cx="18" cy="20" r="14" fill="#2A1810" stroke="#D4922A" stroke-width="2"/>
          <ellipse cx="18" cy="14" rx="10" ry="4" fill="#6B3A2A"/>
          <path d="M28 18 C32 16 34 20 30 22" stroke="#2A1810" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        </svg>
        <h1>Greda CMS</h1>
        <p class="subtitle">Panel de Administración</p>
      </div>

      <div class="login-card">
        <form id="login-form">
          <div class="form-group">
            <label for="email">Correo Electrónico</label>
            <input type="email" id="email" name="email" required autocomplete="email" placeholder="tu@correo.com">
          </div>
          <div class="form-group">
            <label for="password">Contraseña</label>
            <input type="password" id="password" name="password" required autocomplete="current-password" placeholder="••••••••">
          </div>
          <button type="submit" class="btn" id="submit-btn">
            <span class="btn-text">Ingresar</span>
            <span class="loader"></span>
          </button>
          <div class="error-msg" id="error-msg"></div>
        </form>
      </div>

      <div class="demo-hint">
        <strong>Demo:</strong> Usa <code>admin@gredacafe.com</code> / <code>greda</code>
      </div>
    </div>

    <script>
      const form = document.getElementById('login-form') as HTMLFormElement;
      const btn = document.getElementById('submit-btn') as HTMLButtonElement;
      const errorMsg = document.getElementById('error-msg') as HTMLDivElement;

      form?.addEventListener('submit', async (e) => {
        e.preventDefault();
        
        btn.classList.add('loading');
        btn.disabled = true;
        errorMsg.textContent = '';

        const formData = new FormData(form);
        const data = Object.fromEntries(formData.entries());

        try {
          const res = await fetch('/admin/api/auth', {
            method: 'POST',
            headers: { 'Content-Type': 'application/json' },
            body: JSON.stringify(data)
          });

          const result = await res.json();

          if (result.success) {
            window.location.href = '/admin';
          } else {
            errorMsg.textContent = result.message || 'Error de autenticación';
            btn.classList.remove('loading');
            btn.disabled = false;
          }
        } catch (err) {
          errorMsg.textContent = 'Error de conexión';
          btn.classList.remove('loading');
          btn.disabled = false;
        }
      });
    </script>
  </body>
</html>
