---
---
<div class="cart-overlay" id="cart-overlay"></div>

<aside class="cart-drawer" id="cart-drawer">
  <div class="cart-header">
    <h2>Tu Pedido</h2>
    <button class="cart-close" id="cart-close" aria-label="Cerrar carrito">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
        <line x1="18" y1="6" x2="6" y2="18"/><line x1="6" y1="6" x2="18" y2="18"/>
      </svg>
    </button>
  </div>

  <div class="cart-items" id="cart-items-container">
    <!-- Items are added here via JS -->
    <div class="cart-empty" id="cart-empty-message">
      <div class="cart-empty-icon animate-wiggle">☕</div>
      <p>Aún no has agregado ninguna bebida.</p>
      <button class="btn btn-primary btn-small" id="btn-start-order">Ver Menú</button>
    </div>
  </div>

  <div class="cart-footer">
    <div class="cart-total">
      <span>Total:</span>
      <span class="price"><span class="price-currency">$</span><span id="cart-total-price">0.00</span></span>
    </div>
    <button class="btn btn-accent cart-checkout-btn" id="cart-checkout-btn" disabled>
      Finalizar Pedido
    </button>
    <p class="cart-note">* Esta es una versión de demostración.</p>
  </div>
</aside>

<style>
  .cart-overlay {
    position: fixed;
    inset: 0;
    background: rgba(42, 24, 16, 0.4);
    backdrop-filter: blur(4px);
    -webkit-backdrop-filter: blur(4px);
    z-index: 1000;
    opacity: 0;
    visibility: hidden;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .cart-overlay.open {
    opacity: 1;
    visibility: visible;
  }

  .cart-drawer {
    position: fixed;
    top: 0;
    right: 0;
    bottom: 0;
    width: 100%;
    max-width: 400px;
    background: var(--bg-primary);
    z-index: 1001;
    display: flex;
    flex-direction: column;
    transform: translateX(100%);
    transition: transform var(--duration-normal) var(--ease-bounce);
    box-shadow: -10px 0 40px rgba(42, 24, 16, 0.1);
    border-left: 1px solid var(--border-color);
  }

  .cart-drawer.open {
    transform: translateX(0);
  }

  .cart-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: var(--space-xl);
    border-bottom: 1px solid var(--border-color);
    background: var(--bg-secondary);
  }

  .cart-header h2 {
    font-size: 1.5rem;
    margin: 0;
  }

  .cart-close {
    width: 40px;
    height: 40px;
    display: flex;
    align-items: center;
    justify-content: center;
    border-radius: 50%;
    color: var(--text-primary);
    transition: all var(--duration-fast);
  }

  .cart-close:hover {
    background: white;
    color: var(--color-caramel);
  }

  .cart-items {
    flex: 1;
    overflow-y: auto;
    padding: var(--space-xl);
    display: flex;
    flex-direction: column;
    gap: var(--space-md);
  }

  .cart-empty {
    margin: auto;
    text-align: center;
    color: var(--text-muted);
  }

  .cart-empty-icon {
    font-size: 3rem;
    margin-bottom: var(--space-md);
  }

  .cart-empty p {
    margin-bottom: var(--space-lg);
  }

  /* Cart Item UI generated by JS */
  .cart-item {
    display: flex;
    gap: var(--space-md);
    background: white;
    padding: var(--space-md);
    border-radius: var(--radius-md);
    border: 1px solid var(--border-color);
    animation: scaleIn var(--duration-fast) var(--ease-out);
  }

  .cart-item-img {
    width: 60px;
    height: 60px;
    background: var(--bg-secondary);
    border-radius: var(--radius-sm);
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-xs);
  }
  
  .cart-item-img img {
    max-height: 100%;
    object-fit: contain;
  }

  .cart-item-info {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .cart-item-title {
    font-weight: 600;
    font-family: var(--font-body);
    font-size: 0.95rem;
    margin-bottom: 2px;
  }

  .cart-item-price {
    font-size: 0.85rem;
    color: var(--text-muted);
    font-weight: 500;
  }

  .cart-item-actions {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: auto;
    padding-top: var(--space-xs);
  }

  .cart-qty-ctrl {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    background: var(--bg-primary);
    border-radius: var(--radius-full);
    padding: 2px 6px;
  }

  .cart-qty-btn {
    width: 24px;
    height: 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 1rem;
    font-weight: 600;
  }

  .cart-item-remove {
    color: var(--color-rust);
    font-size: 0.8rem;
    font-weight: 500;
    text-decoration: underline;
  }

  .cart-footer {
    padding: var(--space-xl);
    border-top: 1px dashed var(--border-color);
    background: var(--bg-secondary);
  }

  .cart-total {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: var(--space-lg);
    font-weight: 600;
    font-size: 1.1rem;
  }

  .cart-checkout-btn {
    width: 100%;
  }
  
  .cart-checkout-btn:disabled {
    opacity: 0.5;
    pointer-events: none;
    background: var(--text-muted);
    border-color: var(--text-muted);
  }

  .cart-note {
    font-size: 0.75rem;
    text-align: center;
    margin-top: var(--space-md);
    color: var(--text-muted);
  }
</style>

<script>
  // Simple conceptual cart logic
  const cartBtn = document.getElementById('cart-button');
  const cartCloseBtn = document.getElementById('cart-close');
  const cartOverlay = document.getElementById('cart-overlay');
  const cartDrawer = document.getElementById('cart-drawer');
  const addButtons = document.querySelectorAll('.add-to-cart, .btn-add-cart');
  const startOrderBtn = document.getElementById('btn-start-order');
  
  const cartCountEl = document.getElementById('cart-count');
  const cartItemsContainer = document.getElementById('cart-items-container');
  const cartEmptyMessage = document.getElementById('cart-empty-message');
  const cartTotalPrice = document.getElementById('cart-total-price');
  const cartCheckoutBtn = document.getElementById('cart-checkout-btn') as HTMLButtonElement;

  interface CartItem {
    id: string;
    name: string;
    price: number;
    image: string;
    qty: number;
  }

  let cart: CartItem[] = [];

  function openCart() {
    cartOverlay?.classList.add('open');
    cartDrawer?.classList.add('open');
    document.body.style.overflow = 'hidden';
  }

  function closeCart() {
    cartOverlay?.classList.remove('open');
    cartDrawer?.classList.remove('open');
    document.body.style.overflow = '';
  }

  function updateCartUI() {
    const totalItems = cart.reduce((sum, item) => sum + item.qty, 0);
    const totalPrice = cart.reduce((sum, item) => sum + (item.price * item.qty), 0);

    if (cartCountEl) cartCountEl.textContent = String(totalItems);
    if (cartTotalPrice) cartTotalPrice.textContent = totalPrice.toFixed(2);

    if (cart.length === 0) {
      if (cartEmptyMessage) cartEmptyMessage.style.display = 'block';
      if (cartCheckoutBtn) cartCheckoutBtn.disabled = true;
      // Remove all item elements
      Array.from(cartItemsContainer?.children || []).forEach(child => {
        if (child.id !== 'cart-empty-message') {
          child.remove();
        }
      });
    } else {
      if (cartEmptyMessage) cartEmptyMessage.style.display = 'none';
      if (cartCheckoutBtn) cartCheckoutBtn.disabled = false;
      renderCartItems();
    }
  }

  function renderCartItems() {
    if (!cartItemsContainer) return;

    // Keep empty message, remove the rest
    Array.from(cartItemsContainer.children).forEach(child => {
      if (child.id !== 'cart-empty-message') {
        child.remove();
      }
    });

    cart.forEach((item, index) => {
      const itemEl = document.createElement('div');
      itemEl.className = 'cart-item';
      itemEl.innerHTML = `
        <div class="cart-item-img">
          <img src="${item.image}" alt="${item.name}">
        </div>
        <div class="cart-item-info">
          <div class="cart-item-title">${item.name}</div>
          <div class="cart-item-price">$${item.price.toFixed(2)}</div>
          <div class="cart-item-actions">
            <div class="cart-qty-ctrl">
              <button class="cart-qty-btn decrease-qty" data-index="${index}">-</button>
              <span>${item.qty}</span>
              <button class="cart-qty-btn increase-qty" data-index="${index}">+</button>
            </div>
            <button class="cart-item-remove remove-item" data-index="${index}">Quitar</button>
          </div>
        </div>
      `;
      cartItemsContainer.appendChild(itemEl);
    });

    // Attach events to new buttons
    document.querySelectorAll('.decrease-qty').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const idx = Number((e.currentTarget as HTMLElement).dataset.index);
        if (cart[idx].qty > 1) {
          cart[idx].qty--;
        } else {
          cart.splice(idx, 1);
        }
        updateCartUI();
      });
    });

    document.querySelectorAll('.increase-qty').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const idx = Number((e.currentTarget as HTMLElement).dataset.index);
        cart[idx].qty++;
        updateCartUI();
      });
    });

    document.querySelectorAll('.remove-item').forEach(btn => {
      btn.addEventListener('click', (e) => {
        const idx = Number((e.currentTarget as HTMLElement).dataset.index);
        cart.splice(idx, 1);
        updateCartUI();
      });
    });
  }

  // Event Listeners
  cartBtn?.addEventListener('click', openCart);
  cartCloseBtn?.addEventListener('click', closeCart);
  cartOverlay?.addEventListener('click', closeCart);
  
  startOrderBtn?.addEventListener('click', () => {
    window.location.href = '/menu';
  });

  // Mock adding to cart
  addButtons.forEach(btn => {
    btn.addEventListener('click', (e) => {
      e.preventDefault();
      
      const productSlug = (e.currentTarget as HTMLElement).dataset.product;
      // In a real app we would fetch the data. Here we mock from DOM.
      const card = document.getElementById(`product-${productSlug}`) || document.getElementById('product-detail');
      
      if (card) {
        const nameEl = card.querySelector('.product-name') || card.querySelector('.product-title');
        const name = nameEl ? nameEl.textContent : 'Producto';
        
        let price = 0;
        const priceEl = card.querySelector('.price');
        if (priceEl && priceEl.textContent) {
          price = parseFloat(priceEl.textContent.replace('$', '').trim());
        }

        let image = '';
        const imgEl = card.querySelector('img');
        if (imgEl) image = imgEl.src;

        let qty = 1;
        const qtyEl = document.getElementById('qty-value');
        if (qtyEl && document.getElementById('add-to-cart-detail') === e.currentTarget) {
          qty = parseInt(qtyEl.textContent || '1', 10);
        }

        // Check if exists
        const existingItem = cart.find(item => item.id === productSlug);
        if (existingItem) {
          existingItem.qty += qty;
        } else {
          cart.push({ id: productSlug || 'unknown', name: name || 'Café', price, image, qty });
        }

        updateCartUI();
        openCart();
        
        // Add wiggle animation to cart icon
        if (cartBtn) {
          cartBtn.classList.remove('animate-wiggle');
          void cartBtn.offsetWidth; // trigger reflow
          cartBtn.classList.add('animate-wiggle');
        }
      }
    });
  });
</script>
