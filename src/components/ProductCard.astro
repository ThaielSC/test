---
interface Props {
  id: string;
  name: string;
  slug: string;
  description: string;
  price: number;
  category: string;
  image: string;
  available?: boolean;
  featured?: boolean;
}

const { name, slug, description, price, category, image, available = true, featured = false } = Astro.props;
---

<article class:list={['product-card', 'card', { 'unavailable': !available }]} id={`product-${slug}`}>
  <a href={`/producto/${slug}`} class="product-card-link">
    <div class="product-image-wrap">
      <div class="product-image">
        <img src={image} alt={name} loading="lazy" />
      </div>
      {featured && <span class="badge badge-featured">Favorito</span>}
    </div>

    <div class="product-info">
      <span class="badge badge-category">{category}</span>
      <h3 class="product-name">{name}</h3>
      <p class="product-desc">{description}</p>

      <div class="product-footer">
        <span class="price">
          <span class="price-currency">$</span>{price.toFixed(2)}
        </span>
        {available ? (
          <button class="btn btn-accent btn-small add-to-cart" data-product={slug} aria-label={`Agregar ${name} al carrito`}>
            Agregar
            <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
              <line x1="12" y1="5" x2="12" y2="19"/><line x1="5" y1="12" x2="19" y2="12"/>
            </svg>
          </button>
        ) : (
          <span class="out-of-stock">Agotado</span>
        )}
      </div>
    </div>
  </a>
</article>

<style>
  .product-card {
    position: relative;
  }

  .product-card-link {
    display: block;
    text-decoration: none;
    color: inherit;
  }

  .product-image-wrap {
    position: relative;
    overflow: hidden;
    border-radius: var(--radius-lg) var(--radius-lg) 0 0;
  }

  .product-image {
    background: linear-gradient(145deg, var(--color-parchment), var(--color-cream-dark));
    display: flex;
    align-items: center;
    justify-content: center;
    padding: var(--space-2xl) var(--space-xl);
    aspect-ratio: 4 / 3;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .product-card:hover .product-image {
    transform: scale(1.03);
  }

  .product-image img {
    max-height: 160px;
    width: auto;
    object-fit: contain;
    transition: transform var(--duration-normal) var(--ease-bounce);
    filter: drop-shadow(0 8px 16px rgba(42, 24, 16, 0.12));
  }

  .product-card:hover .product-image img {
    transform: translateY(-6px) rotate(-2deg);
  }

  .product-image-wrap .badge {
    position: absolute;
    top: var(--space-md);
    right: var(--space-md);
  }

  .product-info {
    padding: var(--space-lg);
    display: flex;
    flex-direction: column;
    gap: var(--space-sm);
  }

  .product-info .badge-category {
    align-self: flex-start;
    font-size: 0.7rem;
  }

  .product-name {
    font-family: var(--font-display);
    font-size: 1.25rem;
    line-height: 1.3;
  }

  .product-desc {
    font-size: 0.85rem;
    line-height: 1.5;
    color: var(--text-muted);
    display: -webkit-box;
    -webkit-line-clamp: 2;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }

  .product-footer {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-top: var(--space-sm);
    padding-top: var(--space-md);
    border-top: 1px dashed var(--border-color);
  }

  .add-to-cart {
    position: relative;
    z-index: 2;
  }

  .out-of-stock {
    font-size: 0.8rem;
    font-weight: 600;
    color: var(--text-muted);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .unavailable {
    opacity: 0.6;
    pointer-events: none;
  }
</style>
