---
const currentPath = Astro.url.pathname;

const navLinks = [
  { href: '/', label: 'Inicio' },
  { href: '/menu', label: 'Menú' },
  { href: '/about', label: 'Nosotros' },
];
---

<header class="header" id="main-header">
  <div class="container header-inner">
    <a href="/" class="logo" id="logo-link">
      <svg class="logo-icon" width="36" height="36" viewBox="0 0 36 36" fill="none" xmlns="http://www.w3.org/2000/svg">
        <circle cx="18" cy="20" r="14" fill="#2A1810" stroke="#D4922A" stroke-width="2"/>
        <ellipse cx="18" cy="14" rx="10" ry="4" fill="#6B3A2A"/>
        <path d="M28 18 C32 16 34 20 30 22" stroke="#2A1810" stroke-width="2.5" stroke-linecap="round" fill="none"/>
        <!-- Steam lines -->
        <path d="M13 8 Q14 4 13 2" stroke="#D4922A" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.6">
          <animate attributeName="opacity" values="0.6;0.2;0.6" dur="2s" repeatCount="indefinite"/>
          <animate attributeName="d" values="M13 8 Q14 4 13 2;M13 8 Q12 4 13 1;M13 8 Q14 4 13 2" dur="2.5s" repeatCount="indefinite"/>
        </path>
        <path d="M18 7 Q19 3 18 0" stroke="#D4922A" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.4">
          <animate attributeName="opacity" values="0.4;0.1;0.4" dur="2.2s" repeatCount="indefinite"/>
          <animate attributeName="d" values="M18 7 Q19 3 18 0;M18 7 Q17 3 18 -1;M18 7 Q19 3 18 0" dur="2.8s" repeatCount="indefinite"/>
        </path>
        <path d="M23 8 Q24 4 23 2" stroke="#D4922A" stroke-width="1.5" stroke-linecap="round" fill="none" opacity="0.5">
          <animate attributeName="opacity" values="0.5;0.15;0.5" dur="1.8s" repeatCount="indefinite"/>
        </path>
      </svg>
      <span class="logo-text">Greda<span class="logo-accent">Café</span></span>
    </a>

    <nav class="nav" id="main-nav">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['nav-link', { 'active': currentPath === link.href }]}
          id={`nav-${link.label.toLowerCase()}`}
        >
          {link.label}
        </a>
      ))}
    </nav>

    <div class="header-actions">
      <button class="cart-btn animate-wiggle" id="cart-button" aria-label="Carrito de compras">
        <svg width="22" height="22" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="9" cy="21" r="1"/>
          <circle cx="20" cy="21" r="1"/>
          <path d="M1 1h4l2.68 13.39a2 2 0 0 0 2 1.61h9.72a2 2 0 0 0 2-1.61L23 6H6"/>
        </svg>
        <span class="cart-count" id="cart-count">0</span>
      </button>

      <button class="mobile-menu-btn" id="mobile-menu-toggle" aria-label="Abrir menú">
        <span></span>
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <!-- Mobile menu -->
  <div class="mobile-menu" id="mobile-menu">
    <nav class="mobile-nav">
      {navLinks.map(link => (
        <a
          href={link.href}
          class:list={['mobile-nav-link', { 'active': currentPath === link.href }]}
        >
          {link.label}
        </a>
      ))}
    </nav>
  </div>
</header>

<style>
  .header {
    position: fixed;
    top: 0;
    left: 0;
    right: 0;
    z-index: 1000;
    background: rgba(253, 246, 236, 0.9);
    backdrop-filter: blur(12px);
    -webkit-backdrop-filter: blur(12px);
    border-bottom: 1px solid var(--border-color);
    height: var(--header-height);
  }

  .header-inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 100%;
  }

  .logo {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    text-decoration: none;
    z-index: 10;
  }

  .logo-icon {
    flex-shrink: 0;
  }

  .logo-text {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 700;
    color: var(--text-primary);
  }

  .logo-accent {
    color: var(--color-caramel);
    font-style: italic;
  }

  .nav {
    display: flex;
    align-items: center;
    gap: var(--space-xl);
  }

  .nav-link {
    font-weight: 500;
    font-size: 0.95rem;
    color: var(--text-secondary);
    transition: color var(--duration-fast);
    position: relative;
    padding: var(--space-xs) 0;
  }

  .nav-link::after {
    content: '';
    position: absolute;
    bottom: -2px;
    left: 0;
    width: 0;
    height: 2px;
    background: var(--color-caramel);
    border-radius: var(--radius-full);
    transition: width var(--duration-normal) var(--ease-out);
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--text-primary);
  }

  .nav-link:hover::after,
  .nav-link.active::after {
    width: 100%;
  }

  .header-actions {
    display: flex;
    align-items: center;
    gap: var(--space-md);
  }

  .cart-btn {
    position: relative;
    display: flex;
    align-items: center;
    justify-content: center;
    width: 44px;
    height: 44px;
    border-radius: var(--radius-full);
    color: var(--text-primary);
    transition: all var(--duration-fast);
  }

  .cart-btn:hover {
    background: var(--color-cream-dark);
  }

  .cart-count {
    position: absolute;
    top: 4px;
    right: 4px;
    width: 18px;
    height: 18px;
    display: flex;
    align-items: center;
    justify-content: center;
    background: var(--color-caramel);
    color: white;
    font-size: 0.65rem;
    font-weight: 700;
    border-radius: 50%;
  }

  .mobile-menu-btn {
    display: none;
    flex-direction: column;
    gap: 5px;
    padding: 8px;
    z-index: 10;
  }

  .mobile-menu-btn span {
    display: block;
    width: 22px;
    height: 2px;
    background: var(--text-primary);
    border-radius: 2px;
    transition: all var(--duration-normal) var(--ease-out);
  }

  .mobile-menu {
    display: none;
    position: fixed;
    top: var(--header-height);
    left: 0;
    right: 0;
    background: var(--bg-primary);
    border-bottom: 1px solid var(--border-color);
    padding: var(--space-xl);
  }

  .mobile-menu.open {
    display: block;
    animation: fadeIn var(--duration-fast) var(--ease-out);
  }

  .mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .mobile-nav-link {
    font-size: 1.2rem;
    font-weight: 500;
    color: var(--text-secondary);
    padding: var(--space-sm) 0;
    border-bottom: 1px solid var(--border-color);
  }

  .mobile-nav-link.active {
    color: var(--color-caramel);
  }

  @media (max-width: 768px) {
    .nav {
      display: none;
    }

    .mobile-menu-btn {
      display: flex;
    }
  }
</style>

<script>
  const toggleBtn = document.getElementById('mobile-menu-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  toggleBtn?.addEventListener('click', () => {
    mobileMenu?.classList.toggle('open');
  });
</script>
