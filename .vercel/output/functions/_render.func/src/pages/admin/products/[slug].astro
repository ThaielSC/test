---
export const prerender = false;

import AdminLayout from '../../../layouts/AdminLayout.astro';
import { getEntry } from 'astro:content';
import ProductEditor from '../../../components/admin/ProductEditor';

const { slug } = Astro.params;

if (!slug) {
  return Astro.redirect('/admin/products');
}

const product = await getEntry('products', slug);

if (!product) {
  return Astro.redirect('/admin/products');
}

const initialProduct = {
  id: product.id,
  slug: product.id,
  collection: product.collection,
  data: product.data
};
---

<AdminLayout title={`Editando: ${product.data.name}`}>
  <a href="/admin/products" style="display: inline-flex; align-items: center; gap: 0.5rem; text-decoration: none; color: var(--c-text-muted); font-weight: 500; margin-bottom: 1.5rem;">
    ← Volver a productos
  </a>

  <ProductEditor client:only="preact" initialProduct={initialProduct} />
</AdminLayout>
