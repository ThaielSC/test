{
	"version": 3,
	"routes": [
		{
			"handle": "filesystem"
		},
		{
			"src": "^/_astro/(.*)$",
			"headers": {
				"cache-control": "public, max-age=31536000, immutable"
			},
			"continue": true
		},
		{
			"src": "^/_server-islands/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/_image/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/api/auth/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/api/publish/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/checkpoints/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/login/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/pages/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/pages/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/products/new/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/products/([^/]+?)/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/products/?$",
			"dest": "_render"
		},
		{
			"src": "^/admin/?$",
			"dest": "_render"
		},
		{
			"src": "^/404/?$",
			"dest": "_render"
		},
		{
			"src": "^/.*$",
			"dest": "_render",
			"status": 404
		}
	]
}